rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access for everyone to prevent broken images
      allow read: if true;
      // Allow write access only for authenticated admins
      allow write: if request.auth != null && (request.auth.token.email == 'juualleixo@gmail.com' || request.auth.token.email == 'lapallyra@gmail.com');
    }
  }
}
